#!/usr/bin/env sh
# To use, run the following command only once in the project directory:
#   git config core.hooksPath hooks

echo "[tildr] Running build..."

before="$(git diff -- crates/)"

# ----- Build -----
if ! make build; then
  echo "[tildr] Build failed. Commit aborted."
  exit 1
fi

after="$(git diff -- crates/)"

# ----- Checks if the build generated new changes -----
if [ "$before" != "$after" ]; then
  echo ""
  echo "[tildr] Detected changes generated by build or formatter under crates/."
  echo ""
  echo "Run:"
  echo "  make build"
  echo "  git add <TARGET>"
  echo "Then commit again."
  echo ""
  exit 1
fi

echo "[tildr] OK"
exit 0
